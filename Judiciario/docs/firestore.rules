rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ADMINS — Somente leitura. Ninguém sobrescreve pelo client.
    match /admins/{adminName} {
      allow read: if true;
      allow create, delete: if false;
      allow update: if true;
    }

    // SOLICITAÇÕES
    match /solicitacoes/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // PROVAS
    match /provas/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // USUÁRIOS
    match /usuarios/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // CRIMINOSOS
    match /criminosos/{crimId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // INTIMAÇÕES
    match /intimacoes/{intId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // NOTIFICAÇÕES
    match /notificacoes/{notifId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // CONTRATOS
    match /contratos/{contId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // RESULTADOS
    match /resultados/{resId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // ARTIGOS
    match /artigos/{artId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // JURISPRUDÊNCIA
    match /jurisprudencia/{jurId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
  }
}
